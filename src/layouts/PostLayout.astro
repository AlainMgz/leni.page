---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/ui/Nav.astro';
import { readTime } from '../utils/readTime';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  tags: string[];
  severity?: string;
  cve?: string;
  body: string;
}

const { title, description, publishDate, tags, severity, cve, body } = Astro.props as Props;

const rt = readTime(body);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const isFeatured = severity === 'critical' || severity === 'high';
---

<BaseLayout
  title={`${title} — Leni`}
  description={description}
  ogType="article"
  ogImage={`/og/${Astro.url.pathname.split('/').filter(Boolean).pop()}.png`}
  publishDate={publishDate}
  tags={tags}
  author="Alain Alen Magazin (Leni)"
>
  <Nav />

  <main class="main">
    <header class={`post-header animate-enter${isFeatured ? ' post-header--featured' : ''}`}>
      <div class="header-top">
        <a href="/posts" class="back">← posts</a>
        <div class="header-meta">{formatDate(publishDate)} · {rt} min read</div>
      </div>

      <div class="header-tags">
        {severity && (
          <span class={`tag tag-${severity}`}>{severity}</span>
        )}
        {cve && (
          <span class="tag tag-cve">{cve}</span>
        )}
        {tags.map(tag => (
          <span class="tag tag-default">{tag}</span>
        ))}
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
    </header>

    <div class="prose animate-enter">
      <slot />
    </div>
  </main>
</BaseLayout>

<style>
  .main {
    position: relative;
    z-index: 10;
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.75rem 6rem;
  }

  .post-header {
    padding-bottom: 2.5rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
    margin-bottom: 3rem;
  }

  .post-header--featured {
    border-bottom-color: rgba(239,68,68,0.15);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .back {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.40);
    text-decoration: none;
    font-family: var(--font-mono);
    transition: color 0.15s ease;
  }

  .back:hover { color: rgba(255,255,255,0.6); }

  .header-meta {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.4);
    font-family: var(--font-mono);
  }

  .header-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
  }

  .tag-critical  { background: rgba(239,68,68,0.12);  color: rgba(252,165,165,0.9); border: 0.5px solid rgba(239,68,68,0.25); }
  .tag-high      { background: rgba(249,115,22,0.12); color: rgba(253,186,116,0.9); border: 0.5px solid rgba(249,115,22,0.25); }
  .tag-medium    { background: rgba(234,179,8,0.12);  color: rgba(253,224,71,0.9);  border: 0.5px solid rgba(234,179,8,0.25); }
  .tag-low       { background: rgba(34,197,94,0.12);  color: rgba(134,239,172,0.9); border: 0.5px solid rgba(34,197,94,0.25); }
  .tag-info      { background: rgba(99,102,241,0.12); color: rgba(165,180,252,0.9); border: 0.5px solid rgba(99,102,241,0.25); }
  .tag-cve       { background: rgba(239,68,68,0.08);  color: rgba(252,165,165,0.7); border: 0.5px solid rgba(239,68,68,0.2);  font-family: var(--font-mono); }
  .tag-default   { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); border: 0.5px solid rgba(255,255,255,0.1); }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgba(255,255,255,0.92);
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .post-description {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.4);
    margin: 0;
    max-width: 580px;
  }

  /* Prose styles */
  .prose {
    color: rgba(255,255,255,0.75);
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    letter-spacing: -0.01em;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(a) {
    color: rgba(167,139,250,0.9);
    text-decoration: underline;
    text-decoration-color: rgba(167,139,250,0.3);
    transition: color 0.15s ease;
  }

  .prose :global(a:hover) {
    color: rgba(167,139,250,1);
    text-decoration-color: rgba(167,139,250,0.6);
  }

  .prose :global(strong) {
    color: rgba(255,255,255,0.9);
    font-weight: 600;
  }

  .prose :global(em) {
    color: rgba(255,255,255,0.6);
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .prose :global(li) {
    color: rgba(255,255,255,0.65);
  }

  .prose :global(blockquote) {
    border-left: 2px solid rgba(139,92,246,0.4);
    padding: 0.75rem 0 0.75rem 1.25rem;
    margin: 1.5rem 0;
    color: rgba(255,255,255,0.5);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 0.5px solid rgba(255,255,255,0.08);
    margin: 2.5rem 0;
  }

  .prose :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: rgba(255,255,255,0.07);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    padding: 1px 5px;
    color: rgba(167,139,250,0.9);
  }

  /* Code block wrapper */
  .prose :global(pre) {
    border-radius: 10px;
    border: 0.5px solid rgba(255,255,255,0.08);
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  :global(footer.footer) {
    max-width: 720px;
  }
</style>
