---
interface Props {
  level: 'critical' | 'high' | 'medium' | 'low' | 'info';
}

const { level } = Astro.props as Props;
---

<span class={`badge badge-${level}`}>
  <span class="badge-dot"></span>
  {level}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .badge-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .badge-critical { background: rgba(239,68,68,0.12);  color: rgba(252,165,165,0.9); border: 0.5px solid rgba(239,68,68,0.3); }
  .badge-high     { background: rgba(249,115,22,0.12); color: rgba(253,186,116,0.9); border: 0.5px solid rgba(249,115,22,0.3); }
  .badge-medium   { background: rgba(234,179,8,0.12);  color: rgba(253,224,71,0.9);  border: 0.5px solid rgba(234,179,8,0.3); }
  .badge-low      { background: rgba(34,197,94,0.12);  color: rgba(134,239,172,0.9); border: 0.5px solid rgba(34,197,94,0.3); }
  .badge-info     { background: rgba(99,102,241,0.12); color: rgba(165,180,252,0.9); border: 0.5px solid rgba(99,102,241,0.3); }

  .badge-critical .badge-dot { background: rgba(239,68,68,0.8); }
  .badge-high     .badge-dot { background: rgba(249,115,22,0.8); }
  .badge-medium   .badge-dot { background: rgba(234,179,8,0.8); }
  .badge-low      .badge-dot { background: rgba(34,197,94,0.8); }
  .badge-info     .badge-dot { background: rgba(99,102,241,0.8); }
</style>