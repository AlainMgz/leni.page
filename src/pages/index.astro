---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/ui/Nav.astro';
import { getCollection } from 'astro:content';
import { readTime } from '../utils/readTime';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3)
  .map(post => ({
    slug: post.id,
    title: post.data.title,
    description: post.data.description,
    publishDate: post.data.publishDate,
    tags: post.data.tags,
    severity: post.data.severity,
    cve: post.data.cve,
    readTime: readTime(post.body ?? ''),
  }));

const isFeatured = (severity?: string) =>
  severity === 'critical' || severity === 'high';

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="Leni — Security Research">
  <Nav />

  <div class="blobs" aria-hidden="true">
    <div class="blob blob-indigo"></div>
    <div class="blob blob-pink"></div>
    <div class="blob blob-violet"></div>
  </div>

  <main class="main">
    <section class="hero">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        security researcher
      </div>

      <h1 class="hero-title">
        <span class="dim">hi, i'm </span>leni
      </h1>

      <p class="hero-desc" style="text-align: justify;">
        I am a security researcher at the Ledger Donjon, as well as a PhD candidate at ENS Paris.
        I usually write about my personal, academic and professional work, which includes, but is not limited to:
        microarchitecture, iOS/macOS security and side-channel attacks.
      </p>

      <div class="actions">
        <a href="/posts" class="btn-primary">read posts</a>
        <a href="/contact" class="btn-secondary">contact</a>
      </div>
    </section>

    <section class="recent">
      <div class="section-label">recent posts</div>

      {recentPosts.length === 0 ? (
        <p class="empty-state">// no posts yet — first entry incoming</p>
      ) : (
        <div class="posts">
          {recentPosts.map(post => (
            <article class={`post-card${isFeatured(post.severity) ? ' post-card--featured' : ''}`}>
              <a href={`/posts/${post.slug}`} class="post-link">
                <div class="post-top">
                  <div class="post-tags">
                    {post.severity && (
                      <span class={`tag tag-${post.severity}`}>{post.severity}</span>
                    )}
                    {post.cve && (
                      <span class="tag tag-cve">{post.cve}</span>
                    )}
                    {post.tags.map(tag => (
                      <span class="tag tag-default">{tag}</span>
                    ))}
                  </div>
                  <div class="post-meta">
                    {formatDate(post.publishDate)} · {post.readTime} min read
                  </div>
                </div>
                <h2 class="post-title">{post.title}</h2>
                <p class="post-abstract">{post.description}</p>
                <span class="read-more">read more →</span>
              </a>
            </article>
          ))}
        </div>
      )}

      {recentPosts.length > 0 && (
        <a href="/posts" class="all-posts">view all posts →</a>
      )}
    </section>
  </main>
</BaseLayout>

<style>
  .blobs {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .blob { position: absolute; border-radius: 50%; }

  .blob-indigo {
    width: 500px; height: 340px;
    background: radial-gradient(ellipse, rgba(99,102,241,0.18) 0%, transparent 70%);
    top: -80px; left: -100px;
    filter: blur(48px);
  }

  .blob-pink {
    width: 380px; height: 380px;
    background: radial-gradient(ellipse, rgba(236,72,153,0.12) 0%, transparent 70%);
    top: 100px; right: -80px;
    filter: blur(48px);
  }

  .blob-violet {
    width: 300px; height: 220px;
    background: radial-gradient(ellipse, rgba(139,92,246,0.1) 0%, transparent 70%);
    bottom: 60px; left: 35%;
    filter: blur(36px);
  }

  .main {
    position: relative;
    z-index: 10;
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 1.75rem;
  }

  .hero {
    padding-bottom: 4rem;
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(167,139,250,0.8);
    background: rgba(139,92,246,0.1);
    border: 0.5px solid rgba(139,92,246,0.25);
    border-radius: 20px;
    padding: 4px 10px;
    margin-bottom: 1.5rem;
  }

  .eyebrow-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(167,139,250,0.8);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: rgba(255,255,255,0.92);
    margin: 0 0 1rem;
  }

  .dim { color: rgba(255,255,255,0.25); }

  .hero-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.4);
    max-width: 480px;
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.5rem 1.125rem;
    border-radius: 8px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: all 0.15s ease;
  }

  .btn-primary {
    background: rgba(139,92,246,0.85);
    color: rgba(255,255,255,0.95);
    border: 0.5px solid rgba(167,139,250,0.4);
  }

  .btn-primary:hover { background: rgba(139,92,246,1); }

  .btn-secondary {
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.5);
    border: 0.5px solid rgba(255,255,255,0.1);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.75);
  }

  .recent { display: flex; flex-direction: column; gap: 1rem; }

  .section-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .empty-state {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.15);
    font-family: var(--font-mono);
  }

  .posts { display: flex; flex-direction: column; gap: 8px; }

  .post-card {
    background: rgba(255,255,255,0.03);
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    backdrop-filter: blur(8px);
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .post-card:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.12);
  }

  .post-card--featured {
    border-color: rgba(239,68,68,0.2);
    background: rgba(239,68,68,0.04);
  }

  .post-card--featured:hover {
    background: rgba(239,68,68,0.07);
    border-color: rgba(239,68,68,0.3);
  }

  .post-link {
    display: block;
    padding: 18px 20px;
    text-decoration: none;
  }

  .post-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .post-tags { display: flex; gap: 5px; flex-wrap: wrap; }

  .tag {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
  }

  .tag-critical  { background: rgba(239,68,68,0.12);   color: rgba(252,165,165,0.9); border: 0.5px solid rgba(239,68,68,0.25); }
  .tag-high      { background: rgba(249,115,22,0.12);  color: rgba(253,186,116,0.9); border: 0.5px solid rgba(249,115,22,0.25); }
  .tag-medium    { background: rgba(234,179,8,0.12);   color: rgba(253,224,71,0.9);  border: 0.5px solid rgba(234,179,8,0.25); }
  .tag-low       { background: rgba(34,197,94,0.12);   color: rgba(134,239,172,0.9); border: 0.5px solid rgba(34,197,94,0.25); }
  .tag-info      { background: rgba(99,102,241,0.12);  color: rgba(165,180,252,0.9); border: 0.5px solid rgba(99,102,241,0.25); }
  .tag-cve       { background: rgba(239,68,68,0.08);   color: rgba(252,165,165,0.7); border: 0.5px solid rgba(239,68,68,0.2);  font-family: var(--font-mono); }
  .tag-default   { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); border: 0.5px solid rgba(255,255,255,0.1); }

  .post-meta {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.2);
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
    line-height: 1.4;
  }

  .post-abstract {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.35);
    margin: 0 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(167,139,250,0.7);
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .post-card--featured .read-more { color: rgba(252,165,165,0.7); }
  .post-card:hover .read-more { color: rgba(167,139,250,1); }
  .post-card--featured:hover .read-more { color: rgba(252,165,165,1); }

  .all-posts {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    letter-spacing: 0.02em;
    align-self: flex-start;
    transition: color 0.15s ease;
  }

  .all-posts:hover { color: rgba(255,255,255,0.5); }
</style>