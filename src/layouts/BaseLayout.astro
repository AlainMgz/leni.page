---
import '../styles/global.css';
import Searchbar from '../components/interactive/Searchbar';
import { getCollection } from 'astro:content';
import Footer from '../components/ui/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  publishDate?: Date;
  tags?: string[];
  author?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Security research and technical writing.',
  ogType = 'website',
  ogImage,
  publishDate,
  tags = [],
  author = 'Alain Alen Magazin (Leni)',
  noindex = false,
} = Astro.props as Props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Ensure trailing slash consistency
const canonicalHref = canonicalURL.href.endsWith('/')
  ? canonicalURL.href
  : `${canonicalURL.href}/`;

const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og/default.png', Astro.site).href;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const postIndex = allPosts.map(p => ({
  slug: p.id,
  title: p.data.title,
  tags: p.data.tags,
  severity: p.data.severity,
}));

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Leni',
  url: Astro.site?.href,
  description,
  author: {
    '@type': 'Person',
    name: 'Leni',
    url: Astro.site?.href,
  },
};

const articleJsonLd = ogType === 'article' && publishDate ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: ogImageURL,
  author: {
    '@type': 'Person',
    name: author,
    url: Astro.site?.href,
  },
  publisher: {
    '@type': 'Person',
    name: 'Leni',
    url: Astro.site?.href,
  },
  datePublished: publishDate?.toISOString(),
  url: canonicalHref,
  keywords: tags.join(', '),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }
    <link rel="canonical" href={canonicalHref} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Leni" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Article-specific OG -->
    {ogType === 'article' && publishDate && (
      <meta property="article:published_time" content={publishDate.toISOString()} />
    )}
    {ogType === 'article' && tags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
    {ogType === 'article' && (
      <meta property="article:author" content={author} />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:creator" content="@6c656e69" />
    <meta name="twitter:site" content="@6c656e69" />

    <!-- Security -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />

    <!-- JSON-LD -->
    {articleJsonLd
      ? <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
      : <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    }

    <style>
      .animate-enter { opacity: 0; }
    </style>
  </head>
  <body>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const elements = document.querySelectorAll('.animate-enter');
        elements.forEach((el, i) => {
          (el as HTMLElement).style.animationDelay = `${i * 60}ms`;
        });
      });
    </script>
    <Searchbar client:load posts={postIndex} />
    <slot />
    <Footer />
  </body>
</html>
