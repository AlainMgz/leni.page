---
interface Props {
  filename?: string;
}
const { filename } = Astro.props as Props;
---

<div class="terminal">
  <div class="terminal-bar">
    <div class="terminal-dot dot-red"></div>
    <div class="terminal-dot dot-amber"></div>
    <div class="terminal-dot dot-green"></div>
    {filename && <span class="terminal-filename">{filename}</span>}
  </div>
  <div class="terminal-body">
    <slot />
  </div>
</div>

<style>
  .terminal {
    background: #191724;
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.5rem 0;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    background: rgba(255,255,255,0.03);
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
  }

  .terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }

  .dot-red   { background: rgba(239,68,68,0.7); }
  .dot-amber { background: rgba(245,158,11,0.7); }
  .dot-green { background: rgba(34,197,94,0.7); }

  .terminal-filename {
    font-size: 0.625rem;
    color: rgba(255,255,255,0.25);
    font-family: var(--font-mono);
    margin-left: 4px;
  }

  .terminal-body {
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
  }

  .terminal-body :global(.prompt) { color: rgba(139,92,246,0.8); }
  .terminal-body :global(.cmd)    { color: rgba(255,255,255,0.85); }
  .terminal-body :global(.out)    { color: rgba(255,255,255,0.35); }
  .terminal-body :global(.err)    { color: rgba(239,68,68,0.8); }
  .terminal-body :global(.ok)     { color: rgba(34,197,94,0.8); }
</style>