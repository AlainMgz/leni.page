---
interface Props {
  url: string;
  title?: string;
  description?: string;
  image?: string;
  favicon?: string;
}

const { url, title, description, image, favicon } = Astro.props as Props;

const domain = (() => {
  try { return new URL(url).hostname.replace(/^www\./, ''); }
  catch { return url; }
})();

// Fetch OG data at build time if no props provided
let meta = { title, description, image, favicon };

if (!title || !description) {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (compatible; bot/1.0)' },
      signal: AbortSignal.timeout(4000),
    });
    const html = await res.text();

    const get = (prop: string) => {
      const m = html.match(new RegExp(`<meta[^>]+property=["']og:${prop}["'][^>]+content=["']([^"']+)["']`, 'i'))
        || html.match(new RegExp(`<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:${prop}["']`, 'i'));
      return m?.[1] ?? undefined;
    };

    const getTitle = () => {
      const m = html.match(/<title[^>]*>([^<]+)<\/title>/i);
      return m?.[1]?.trim() ?? undefined;
    };

    if (!meta.title)       meta.title       = get('title')       ?? getTitle();
    if (!meta.description) meta.description = get('description') ?? undefined;
    if (!meta.image)       meta.image       = get('image')       ?? undefined;
    if (!meta.favicon)     meta.favicon = `https://icons.duckduckgo.com/ip3/${domain}.ico`;
  } catch {
    // fail silently — fallback to URL display
    if (!meta.favicon) meta.favicon = `https://icons.duckduckgo.com/ip3/${domain}.ico`;
  }
}
---

<a href={url} target="_blank" rel="noopener noreferrer" class="link-preview">
  {meta.image && (
    <div class="link-preview__image">
      <img src={meta.image} alt="" loading="lazy" decoding="async" />
    </div>
  )}
  <div class="link-preview__body">
    <div class="link-preview__meta">
      {meta.favicon && <img src={meta.favicon} alt="" class="link-preview__favicon" width="14" height="14" />}
      <span class="link-preview__domain">{domain}</span>
      <span class="link-preview__arrow">↗</span>
    </div>
    {meta.title && <p class="link-preview__title">{meta.title}</p>}
    {meta.description && <p class="link-preview__description">{meta.description}</p>}
  </div>
</a>

<style>
  .link-preview {
    display: flex;
    gap: 0;
    border: 0.5px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, background 0.15s ease;
    margin: 1.5rem 0;
    max-width: 100%;
  }

  .link-preview:hover {
    border-color: rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.04);
  }

  .link-preview__image {
    width: 160px;
    flex-shrink: 0;
    overflow: hidden;
    border-right: 0.5px solid rgba(255,255,255,0.06);
  }

  .link-preview__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .link-preview__body {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .link-preview__meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .link-preview__favicon {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .link-preview__domain {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
  }

  .link-preview__arrow {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.2);
    margin-left: auto;
    flex-shrink: 0;
  }

  .link-preview__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-preview__description {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .link-preview {
      flex-direction: column;
    }
    .link-preview__image {
      width: 100%;
      height: 120px;
      border-right: none;
      border-bottom: 0.5px solid rgba(255,255,255,0.06);
    }
  }
</style>

